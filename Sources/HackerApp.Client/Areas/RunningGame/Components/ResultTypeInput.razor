@using HackerApp.Client.Areas.Shared.Models.Pgr
<InputSelect style="width: 60px;" Value="ResultType"
             ValueExpression="() => ResultType"
             TValue="GameRoundPlayerResultType"
             ValueChanged="HandleValueChangedAsync">
    <option value="@GameRoundPlayerResultType.None">-</option>
    <option value="@GameRoundPlayerResultType.HackedGewonnenSafer">Gehackt G*</option>
    <option value="@GameRoundPlayerResultType.HackedGewonnen">Gehackt G</option>
    <option value="@GameRoundPlayerResultType.HackedVerloren">Gehackt V</option>
    <option value="@GameRoundPlayerResultType.MitgegangenGewonnen">Mit G</option>
    <option value="@GameRoundPlayerResultType.MitgegangenVerloren">Mit V</option>
</InputSelect>